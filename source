local Button = MainTab:CreateButton({
   Name = "Sneak",
   Callback = function()
       local Players = game:GetService("Players")
       local ReplicatedStorage = game:GetService("ReplicatedStorage")
       local localPlayer = Players.LocalPlayer

       local function fireSneak(targetPlayer)
           local args = {targetPlayer}
           ReplicatedStorage:WaitForChild("events"):WaitForChild("SneakRequestEvents"):WaitForChild("SendSneakToServer"):FireServer(unpack(args))
       end

       localPlayer.Chatted:Connect(function(message)
           if message:sub(1, 6):lower() == ":sneak" then
               local argument = message:sub(8):match("^%s*(.-)%s*$")
               
               if argument and argument ~= "" then
                   if argument:lower() == "all" then
                       local allPlayers = Players:GetPlayers()
                       for _, player in ipairs(allPlayers) do
                           if player ~= localPlayer then
                               fireSneak(player)
                               print("Sneaking " .. player.Name)
                           end
                       end
                       print("Sneaked " .. (#allPlayers - 1) .. " players total")
                   else
                       local targetPlayer = Players:FindFirstChild(argument)
                       
                       if targetPlayer then
                           fireSneak(targetPlayer)
                           print("Sneaking " .. argument)
                       else
                           print("Player '" .. argument .. "' not found")
                       end
                   end
               else
                   print("Please provide a username: :sneak <username> or :sneak all")
               end
           end
       end)
   end,
})

